{
  "info": {
    "name": "Employee Management TypeORM API",
    "_postman_id": "36a5f2c4-9b71-4a75-9a7d-employee-management",
    "description": "Import this collection in Postman. First run Auth/Register Admin or Auth/Login, then protected routes will use the saved {{token}} bearer token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "let json = {};",
          "try { json = pm.response.json(); } catch (e) {}",
          "if (json.token) pm.collectionVariables.set('token', json.token);",
          "if (json.employee && json.employee.employeeCode) pm.collectionVariables.set('employeeCode', json.employee.employeeCode);"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "employeeCode",
      "value": "TX-001"
    },
    {
      "key": "adminSetupSecret",
      "value": ""
    }
  ],
  "item": [
    {
